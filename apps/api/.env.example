DATABASE_URL="postgresql://postgres:postgres@localhost:5432/momito?schema=public"
# MOM-020: Neon (and other connection poolers) need a separate non-pooled URL for
# `prisma migrate`. Without a pooler (local Postgres, most self-hosted setups), set
# this to the same value as DATABASE_URL. With Neon, use its "direct connection"
# string (no `-pooler` in the hostname) here instead.
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/momito?schema=public"
JWT_SECRET="replace-with-a-long-random-secret"
PORT=3001
CORS_ORIGIN="http://localhost:3000"
NODE_ENV="development"
