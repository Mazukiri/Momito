DATABASE_URL="postgresql://postgres:postgres@localhost:5432/momito?schema=public"
# MOM-020: Neon (and other connection poolers) need a separate non-pooled URL for
# `prisma migrate`. Without a pooler (local Postgres, most self-hosted setups), set
# this to the same value as DATABASE_URL. With Neon, use its "direct connection"
# string (no `-pooler` in the hostname) here instead.
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/momito?schema=public"
JWT_SECRET="replace-with-a-long-random-secret"
# How long an issued access token stays valid. Defaults to 30d if unset — this
# is a single-user, localStorage-Bearer app (see ADR-0001/0009), so a long
# expiry means a user studying daily on their phone isn't logged out every day.
JWT_EXPIRES_IN="30d"
PORT=3001
CORS_ORIGIN="http://localhost:3000"
NODE_ENV="development"

# B1 (MOM-018): once one account exists, registration is refused by default so
# a deployed instance can't be silently taken over by a stranger who finds the
# URL. Set to "true" only if you actually want open multi-user registration.
ALLOW_MULTI_USER_REGISTRATION="false"

# B2: overrides the seeded demo account's email/password. Leave unset for local
# dev (falls back to demo@momito.local / MomitoDemo123!, printed by `pnpm
# db:seed`); set both before seeding a real public deployment so it isn't
# left with the source-committed default credentials.
# SEED_USER_EMAIL="you@example.com"
# SEED_USER_PASSWORD="a-real-password-not-in-source-control"

# Workstream C (AI grading): unset/absent means the feature reports
# unavailable and the app is fully usable on self-rating alone — no key is
# required to run Momito. See docs/adr/0007-ai-grading-scaffold.md.
# ANTHROPIC_API_KEY="sk-ant-..."
# ANTHROPIC_MODEL="claude-opus-4-8"
# AI_DAILY_BUDGET_USD="1.00"
