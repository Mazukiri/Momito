generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // MOM-020: Neon (and other poolers) need a separate non-pooled connection for
  // `prisma migrate`. directUrl is optional locally — Prisma falls back to `url`
  // when DIRECT_URL is unset, so this does not affect existing setups. No models
  // changed; no migration is generated by this datasource-only edit.
  directUrl = env("DIRECT_URL")
}

model User {
  id             String             @id @default(uuid()) @db.Uuid
  email          String             @unique
  passwordHash   String             @map("password_hash")
  name           String
  role           String             @default("user")
  // Embedded in every issued JWT as `tv`; bumped on logout so all previously
  // issued (otherwise stateless, non-expiring-for-30-days) tokens are
  // rejected immediately instead of staying valid until they naturally expire.
  tokenVersion   Int                @default(0) @map("token_version")
  createdAt      DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  questions      Question[]
  sessions       InterviewSession[]
  answerAttempts AnswerAttempt[]
  stories        Story[]
  profile        Profile?
  profileScores  ProfileScore[]
  careerGoals    CareerGoal[]
  missions       Mission[]
  missionCompetencies MissionCompetencyState[]
  weeklyPlans    WeeklyPlan[]
  planItems      PlanItem[]
  missionCheckIns MissionCheckIn[]
  jobApplications JobApplication[]
  jobEvents      JobEvent[]
  tasks          Task[]
  reminders      Reminder[]
  reviewStates   ReviewState[]
  learningSources LearningSource[]
  learningHighlights LearningHighlight[]
  learningEvidence LearningEvidence[]
  readwiseConnection ReadwiseConnection?
  readwiseSyncRuns ReadwiseSyncRun[]
  aiUsage        AiUsage[]
  pushSubscriptions PushSubscription[]
  weaknessSignals WeaknessSignal[]
  interviewRounds InterviewRound[]

  @@map("users")
}

// Web Push: one row per browser/device that has granted notification
// permission and subscribed (docs/adr/0008-web-push-notifications.md). A
// user can have several (phone + desktop); dead subscriptions (410 Gone from
// the push service) are pruned by PushService.
model PushSubscription {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}

// Workstream C: per-user daily token/cost tallies for the AI grading feature
// (docs/adr/0007-ai-grading-scaffold.md). One row per user per day.
model AiUsage {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  day          DateTime @db.Date
  requests     Int      @default(0)
  inputTokens  Int      @default(0) @map("input_tokens")
  outputTokens Int      @default(0) @map("output_tokens")
  costUsd      Float    @default(0) @map("cost_usd")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, day])
  @@map("ai_usage")
}

model Topic {
  id             String          @id @default(uuid()) @db.Uuid
  name           String
  parentTopicId  String?         @map("parent_topic_id") @db.Uuid
  description    String?
  createdAt      DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  parentTopic    Topic?          @relation("TopicHierarchy", fields: [parentTopicId], references: [id], onDelete: SetNull)
  childTopics    Topic[]         @relation("TopicHierarchy")
  questions      Question[]
  tasks          Task[]
  learningHighlights LearningHighlight[]
  learningEvidence LearningEvidence[]

  @@index([parentTopicId])
  @@map("topics")
}

model Company {
  id        String            @id @default(uuid()) @db.Uuid
  name      String
  region    String?
  notes     String?
  // MOM-121 (ADR-0010 / D-017): structured interview intelligence. Json map/array
  // (not relation tables) because the area/track taxonomies are TS-owned
  // (CAREER_ROLE_AREA_IDS / CAREER_ROLE_TRACK_IDS) and the only query is
  // "load one company, weight its readiness" — never "find companies by area".
  focusAreas        Json    @default("{}") @map("focus_areas")       // { [CareerRoleAreaId]: 1-5 weight }
  roleTrackIds      Json    @default("[]") @map("role_track_ids")    // CareerRoleTrackId[]
  interviewProcess  Json    @default("[]") @map("interview_process") // ordered [{ roundType, label, notes? }]
  sponsorshipStatus String? @map("sponsorship_status")              // VISA_TAGS value; null = no data
  compBand          String? @map("comp_band")                       // free text
  createdAt DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  questions QuestionCompany[]
  stories   StoryCompany[]
  jobApplications JobApplication[]

  @@map("companies")
}

model Question {
  id               String            @id @default(uuid()) @db.Uuid
  title            String
  prompt           String
  type             String
  difficulty       String
  topicId          String            @map("topic_id") @db.Uuid
  subtopic         String?
  referenceAnswer  String?           @map("reference_answer")
  notes            String?
  sourceUrl        String?           @map("source_url")
  roleTags         Json              @default("[]") @map("role_tags")
  areaTags         Json              @default("[]") @map("area_tags")
  patternTags      Json              @default("[]") @map("pattern_tags")
  estimatedMinutes Int?              @map("estimated_minutes")
  rubric           Json              @default("{}")
  importance       Int               @default(1)
  createdByUserId  String            @map("created_by_user_id") @db.Uuid
  createdAt        DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  topic            Topic             @relation(fields: [topicId], references: [id], onDelete: Restrict)
  createdBy        User              @relation(fields: [createdByUserId], references: [id], onDelete: Cascade)
  companies        QuestionCompany[]
  sessionQuestions SessionQuestion[]
  answerAttempts   AnswerAttempt[]
  learningEvidence LearningEvidence[]
  storyPrompts     StoryPrompt[]

  @@index([topicId])
  @@index([createdByUserId])
  @@index([type])
  @@index([difficulty])
  @@index([importance])
  @@map("questions")
}

model QuestionCompany {
  questionId String   @map("question_id") @db.Uuid
  companyId  String   @map("company_id") @db.Uuid
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@id([questionId, companyId])
  @@index([companyId])
  @@map("question_companies")
}

// MOM-063 (ADR-0003): Story Bank, plan §7.5/§8.2. STAR-shaped, user-authored,
// reviewable via ADR-0002's polymorphic ReviewState (objectType='story') —
// no FK from ReviewState.objectId to this table, by the same design already
// used for Question.
model Story {
  id                String        @id @default(uuid()) @db.Uuid
  userId            String        @map("user_id") @db.Uuid
  title             String
  situation         String
  task              String
  action            String
  result            String
  metrics           String?
  competencyTags    String[]      @default([]) @map("competency_tags")
  followUpQuestions String[]      @default([]) @map("follow_up_questions")
  createdAt         DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  companies         StoryCompany[]
  prompts           StoryPrompt[]

  @@index([userId])
  @@map("stories")
}

model StoryCompany {
  storyId   String  @map("story_id") @db.Uuid
  companyId String  @map("company_id") @db.Uuid
  story     Story   @relation(fields: [storyId], references: [id], onDelete: Cascade)
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@id([storyId, companyId])
  @@index([companyId])
  @@map("story_companies")
}

// MOM-066: links a Story to a behavioral Question it can answer. Many-to-many
// (a story can support multiple prompts; a prompt can be answered by multiple
// stories) — deliberately not 1:1, since the whole point of a story bank is
// reusing one strong story across several prompts.
model StoryPrompt {
  id         String   @id @default(uuid()) @db.Uuid
  storyId    String   @map("story_id") @db.Uuid
  questionId String   @map("question_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  story      Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([storyId, questionId])
  @@index([questionId])
  @@map("story_prompts")
}

model InterviewSession {
  id               String            @id @default(uuid()) @db.Uuid
  userId           String            @map("user_id") @db.Uuid
  title            String?
  sessionType      String            @map("session_type")
  status           String            @default("active")
  roleTrackId      String?           @map("role_track_id")
  area             String?
  practiceMode     String?           @map("practice_mode")
  jobApplicationId String?           @map("job_application_id") @db.Uuid
  missionId        String?           @map("mission_id") @db.Uuid
  startedAt        DateTime          @default(now()) @map("started_at") @db.Timestamptz(6)
  endedAt          DateTime?         @map("ended_at") @db.Timestamptz(6)
  createdAt        DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobApplication   JobApplication?   @relation(fields: [jobApplicationId], references: [id], onDelete: SetNull)
  mission          Mission?          @relation(fields: [missionId], references: [id], onDelete: SetNull)
  sessionQuestions SessionQuestion[]
  answerAttempts   AnswerAttempt[]

  @@index([userId])
  @@index([status])
  @@index([roleTrackId])
  @@index([jobApplicationId])
  @@index([missionId])
  @@map("interview_sessions")
}

model SessionQuestion {
  id         String           @id @default(uuid()) @db.Uuid
  sessionId  String           @map("session_id") @db.Uuid
  questionId String           @map("question_id") @db.Uuid
  order      Int
  createdAt  DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  session    InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  question   Question         @relation(fields: [questionId], references: [id], onDelete: Restrict)

  @@unique([sessionId, order])
  @@index([questionId])
  @@map("session_questions")
}

model AnswerAttempt {
  id         String            @id @default(uuid()) @db.Uuid
  userId     String            @map("user_id") @db.Uuid
  sessionId  String?           @map("session_id") @db.Uuid
  questionId String            @map("question_id") @db.Uuid
  answerText String            @map("answer_text")
  selfRating Int?              @map("self_rating")
  aiScore    Float?            @map("ai_score")
  aiFeedback String?           @map("ai_feedback")
  correctness String?
  confidence Int?
  timeSpentSeconds Int?        @map("time_spent_seconds")
  hintUsed   Boolean           @default(false) @map("hint_used")
  rubricScore Float?           @map("rubric_score")
  needsReview Boolean          @default(false) @map("needs_review")
  // MOM-028 (DECISIONS.MD D-003 outcome): the genuinely-missing reflection
  // fields, human-approved migration. missTags draws from plan §5.4's
  // WeaknessSignal.reason taxonomy (packages/shared MISS_TAG_REASONS) but
  // isn't DB-constrained to it — validated at the DTO layer instead.
  missTags   String[]          @default([]) @map("miss_tags")
  reflectionNote String?       @map("reflection_note")
  // MOM-126/128 (ADR-0011): target-scope columns so a study signal can be
  // attributed to a specific role track / competency area without joining
  // through the (optional) session. Populated on create by MOM-128; existing
  // rows are NULL (additive, no backfill).
  roleTrackId String?          @map("role_track_id")
  area       String?
  language   String?
  complexity String?
  createdAt  DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  session    InterviewSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  question   Question          @relation(fields: [questionId], references: [id], onDelete: Restrict)

  @@index([userId])
  // Dashboard's recent-attempts query filters by userId and orders by
  // createdAt desc (dashboard.service.ts) — this composite index covers that
  // access pattern directly instead of relying on the single-column index
  // plus a sort.
  @@index([userId, createdAt])
  // MOM-129 grounds per-area readiness on graded attempts; this covers the
  // per-user, per-area group-by.
  @@index([userId, area])
  @@index([sessionId])
  @@index([questionId])
  @@index([needsReview])
  @@map("answer_attempts")
}

model Profile {
  id          String         @id @default(uuid()) @db.Uuid
  userId      String         @unique @map("user_id") @db.Uuid
  name        String?
  email       String?
  githubUrl   String?        @map("github_url")
  linkedinUrl String?        @map("linkedin_url")
  skills      Json           @default("[]")
  experience  Json           @default("[]")
  education   Json           @default("[]")
  projects    Json           @default("[]")
  rawCvText   String?        @map("raw_cv_text")
  createdAt   DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  scores      ProfileScore[]

  @@index([userId])
  @@map("profiles")
}

model ProfileScore {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  profileId       String   @map("profile_id") @db.Uuid
  targetId        String   @map("target_id")
  targetLabel     String   @map("target_label")
  roleTemplate    String   @map("role_template")
  jdText          String?  @map("jd_text")
  skillsMatch     Float    @map("skills_match")
  projectQuality  Float    @map("project_quality")
  experienceDepth Float    @map("experience_depth")
  presentation    Float
  skillsGaps      Json     @default("[]") @map("skills_gaps")
  projectGaps     Json     @default("[]") @map("project_gaps")
  experienceGaps  Json     @default("[]") @map("experience_gaps")
  presentationGaps Json    @default("[]") @map("presentation_gaps")
  suggestions     Json     @default("[]")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile         Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([profileId])
  @@index([targetId])
  @@map("profile_scores")
}

model CareerGoal {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  roleTrackId String   @map("role_track_id")
  horizon     String   @default("6_months")
  status      String   @default("active")
  targetDate  DateTime? @map("target_date") @db.Date
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  missions    Mission[]

  @@unique([userId, roleTrackId])
  @@index([userId])
  @@index([status])
  @@map("career_goals")
}

model JobApplication {
  id                String             @id @default(uuid()) @db.Uuid
  userId            String             @map("user_id") @db.Uuid
  company           String
  // MOM-122 (ADR-0010 / D-017): optional link to the curated catalog. Free-text
  // `company` is KEPT as fallback + display; SetNull so pipeline data survives a
  // catalog deletion. Backfilled by exact case-insensitive name match.
  companyId         String?            @map("company_id") @db.Uuid
  companyRef        Company?           @relation(fields: [companyId], references: [id], onDelete: SetNull)
  roleTitle         String             @map("role_title")
  url               String?
  location          String?
  status            String             @default("saved")
  roleTrackId       String?            @map("role_track_id")
  jdText            String?            @map("jd_text")
  appliedDate       DateTime?          @map("applied_date") @db.Date
  deadline          DateTime?          @db.Date
  source            String?
  referralName      String?            @map("referral_name")
  visaTag           String?            @map("visa_tag")
  h1bCountLastYear  Int?               @map("h1b_count_last_year")
  compensationNotes String?            @map("compensation_notes")
  notes             String?
  createdAt         DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  missions          Mission[]
  events            JobEvent[]
  tasks             Task[]
  reminders         Reminder[]
  sessions          InterviewSession[]
  learningEvidence  LearningEvidence[]
  weaknessSignals   WeaknessSignal[]
  interviewRounds   InterviewRound[]

  @@index([userId])
  @@index([status])
  @@index([roleTrackId])
  @@index([deadline])
  @@index([companyId])
  @@map("job_applications")
}

model JobEvent {
  id               String         @id @default(uuid()) @db.Uuid
  userId           String         @map("user_id") @db.Uuid
  jobApplicationId String         @map("job_application_id") @db.Uuid
  type             String
  title            String
  notes            String?
  // MOM-103/104: structured transition endpoints for a `status_change` event
  // (null for other event types). Backfilled from the machine-written `title`.
  fromStatus       String?        @map("from_status")
  toStatus         String?        @map("to_status")
  eventAt          DateTime       @map("event_at") @db.Timestamptz(6)
  createdAt        DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobApplication   JobApplication @relation(fields: [jobApplicationId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([jobApplicationId])
  @@index([eventAt])
  @@map("job_events")
}

model Task {
  id                    String             @id @default(uuid()) @db.Uuid
  userId                String             @map("user_id") @db.Uuid
  title                 String
  notes                 String?
  type                  String             @default("study")
  status                String             @default("todo")
  priority              String             @default("medium")
  roleTrackId           String?            @map("role_track_id")
  area                  String?
  topicId               String?            @map("topic_id") @db.Uuid
  jobApplicationId      String?            @map("job_application_id") @db.Uuid
  interviewRoundId      String?            @map("interview_round_id") @db.Uuid
  missionId             String?            @map("mission_id") @db.Uuid
  plannedFor            DateTime?          @map("planned_for") @db.Timestamptz(6)
  dueDate               DateTime?          @map("due_date") @db.Timestamptz(6)
  recurrence            String?
  reminderOffsetMinutes Int?               @map("reminder_offset_minutes")
  completedAt           DateTime?          @map("completed_at") @db.Timestamptz(6)
  snoozedUntil          DateTime?          @map("snoozed_until") @db.Timestamptz(6)
  createdAt             DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  user                  User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic                 Topic?             @relation(fields: [topicId], references: [id], onDelete: SetNull)
  jobApplication        JobApplication?    @relation(fields: [jobApplicationId], references: [id], onDelete: Cascade)
  interviewRound        InterviewRound?    @relation(fields: [interviewRoundId], references: [id], onDelete: SetNull)
  mission               Mission?           @relation(fields: [missionId], references: [id], onDelete: SetNull)
  reminders             Reminder[]
  learningEvidence      LearningEvidence[]
  planItems             PlanItem[]

  @@index([userId])
  @@index([status])
  @@index([type])
  @@index([roleTrackId])
  @@index([area])
  @@index([dueDate])
  @@index([plannedFor])
  @@index([missionId])
  @@index([interviewRoundId])
  @@map("tasks")
}

model Reminder {
  id               String          @id @default(uuid()) @db.Uuid
  userId           String          @map("user_id") @db.Uuid
  taskId           String?         @map("task_id") @db.Uuid
  jobApplicationId String?         @map("job_application_id") @db.Uuid
  interviewRoundId String?         @map("interview_round_id") @db.Uuid
  type             String
  title            String
  dueAt            DateTime        @map("due_at") @db.Timestamptz(6)
  status           String          @default("pending")
  lastTriggeredAt  DateTime?       @map("last_triggered_at") @db.Timestamptz(6)
  dismissedAt      DateTime?       @map("dismissed_at") @db.Timestamptz(6)
  createdAt        DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  task             Task?           @relation(fields: [taskId], references: [id], onDelete: Cascade)
  jobApplication   JobApplication? @relation(fields: [jobApplicationId], references: [id], onDelete: Cascade)
  interviewRound   InterviewRound? @relation(fields: [interviewRoundId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([dueAt])
  @@index([taskId])
  @@index([jobApplicationId])
  @@index([interviewRoundId])
  @@map("reminders")
}

model LearningSource {
  id                 String              @id @default(uuid()) @db.Uuid
  userId             String              @map("user_id") @db.Uuid
  externalId         String?             @map("external_id")
  title              String
  author             String?
  url                String?
  sourceType         String              @map("source_type")
  category           String?
  summary            String?
  coverImageUrl      String?             @map("cover_image_url")
  readwiseUrl        String?             @map("readwise_url")
  isDeleted          Boolean             @default(false) @map("is_deleted")
  createdAt          DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  highlights         LearningHighlight[]
  learningEvidence   LearningEvidence[]

  @@unique([userId, externalId])
  @@index([userId])
  @@index([sourceType])
  @@map("learning_sources")
}

model LearningHighlight {
  id                 String             @id @default(uuid()) @db.Uuid
  userId             String             @map("user_id") @db.Uuid
  sourceId           String?            @map("source_id") @db.Uuid
  readwiseHighlightId Int?              @map("readwise_highlight_id")
  text               String
  note               String?
  color              String?
  location           String?
  locationType       String?            @map("location_type")
  highlightedAt      DateTime?          @map("highlighted_at") @db.Timestamptz(6)
  readwiseUpdatedAt  DateTime?          @map("readwise_updated_at") @db.Timestamptz(6)
  isDeleted          Boolean            @default(false) @map("is_deleted")
  reviewedAt         DateTime?          @map("reviewed_at") @db.Timestamptz(6)
  usefulness         String?
  roleTrackId        String?            @map("role_track_id")
  area               String?
  topicId            String?            @map("topic_id") @db.Uuid
  createdAt          DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  source             LearningSource?    @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  topic              Topic?             @relation(fields: [topicId], references: [id], onDelete: SetNull)
  evidence           LearningEvidence[]

  @@unique([userId, readwiseHighlightId])
  @@index([userId])
  @@index([sourceId])
  @@index([roleTrackId])
  @@index([area])
  @@index([topicId])
  @@index([reviewedAt])
  @@map("learning_highlights")
}

model LearningEvidence {
