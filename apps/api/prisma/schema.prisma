// MOM-027: FSRS review scheduling state, per ADR-0002/D-005. objectId is
// intentionally polymorphic with no DB-level foreign key (it can point at a
// Question today, and a Story/other reviewable object later) — the service
// layer is responsible for validating objectType values and, per ADR-0002's
// SPIKE-003 finding, deleting orphaned rows when a referenced object is
// hard-deleted (see Question.remove() in questions.service.ts).
model ReviewState {
  id             String    @id @default(uuid()) @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  objectType     String    @map("object_type")
  objectId       String    @map("object_id") @db.Uuid
  stability      Float     @default(0)
  difficulty     Float     @default(0)
  due            DateTime  @default(now()) @db.Timestamptz(6)
  state          Int       @default(0)
  reps           Int       @default(0)
  lapses         Int       @default(0)
  suspended      Boolean   @default(false)
  lastReviewedAt DateTime? @map("last_reviewed_at") @db.Timestamptz(6)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, objectType, objectId])
  @@index([userId, due])
  @@map("review_states")
}

// MOM-126/127 (ADR-0011 / D-013, plan §5.4): persistent weakness signals for
// the CareerOS loop. The derived weakness engine (weaknesses.service) still
// handles practice struggles on the fly; this table stores only the signals
// that CANNOT be re-derived — interview debriefs (source='debrief') and manual
// entries — plus the state the derived path can't hold: severity accrual,
// decay, and a repair/dismiss lifecycle. `summary()` merges both sources.
// Target scoping is by roleTrackId/area/jobApplicationId; companyId is
// deliberately deferred until the Company FK migration (MOM-122) lands.
model WeaknessSignal {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  signalType       String    @map("signal_type") // reason | pattern | topic | area | round
  key              String                        // MissTagReason | patternTag | topicId | areaId | roundType
  label            String
  roleTrackId      String?   @map("role_track_id")
  area             String?
  jobApplicationId String?   @map("job_application_id") @db.Uuid
  severity         Float     @default(1)
  occurrences      Int       @default(1)
  source           String                         // attempt | debrief | manual
  status           String    @default("open")     // open | repairing | resolved | dismissed
  lastSignalAt     DateTime  @map("last_signal_at") @db.Timestamptz(6)
  resolvedAt       DateTime? @map("resolved_at") @db.Timestamptz(6)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobApplication   JobApplication? @relation(fields: [jobApplicationId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([jobApplicationId])
  @@index([roleTrackId, area])
  @@map("weakness_signals")
}

// MOM-109/110 (ADR-0013 / D-016, Track N): a first-class interview round on a
// JobApplication, replacing the JobEvent-as-interview hack. Carries the schedule
// (drives reminders/countdown/auto-prep) and the outcome+debrief that MOM-113
// turns into WeaknessSignals — the edge that closes the CareerOS loop. Owns no
// prep/practice rows: a round's prep is an ordinary Task and its mock an ordinary
// InterviewSession, attributed by a nullable interviewRoundId back-ref added when
// needed (MOM-111/141) — never a copy (avoids the PlanItem/Task dual-write).
model InterviewRound {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  jobApplicationId String    @map("job_application_id") @db.Uuid
  roundType        String    @map("round_type")   // INTERVIEW_ROUND_TYPES
  sequence         Int       @default(0)
  scheduledAt      DateTime? @map("scheduled_at") @db.Timestamptz(6)
  durationMinutes  Int?      @map("duration_minutes")
  interviewer      String?
  outcome          String    @default("pending")  // INTERVIEW_ROUND_OUTCOMES
  debrief          String?
  areasWeak        String[]  @default([]) @map("areas_weak")  // CAREER_ROLE_AREA_IDS
  missTags         String[]  @default([]) @map("miss_tags")   // MISS_TAG_REASONS
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobApplication   JobApplication @relation(fields: [jobApplicationId], references: [id], onDelete: Cascade)
  tasks            Task[]
  reminders        Reminder[]

  @@index([userId])
  @@index([jobApplicationId])
  @@index([scheduledAt])
  @@map("interview_rounds")
}
