generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // MOM-020: Neon (and other poolers) need a separate non-pooled connection for
  // `prisma migrate`. directUrl is optional locally — Prisma falls back to `url`
  // when DIRECT_URL is unset, so this does not affect existing setups. No models
  // changed; no migration is generated by this datasource-only edit.
  directUrl = env("DIRECT_URL")
}

model User {
  id             String             @id @default(uuid()) @db.Uuid
  email          String             @unique
  passwordHash   String             @map("password_hash")
  name           String
  role           String             @default("user")
  createdAt      DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  questions      Question[]
  sessions       InterviewSession[]
  answerAttempts AnswerAttempt[]
  studyPlanItems StudyPlanItem[]
  profile        Profile?
  profileScores  ProfileScore[]
  careerGoals    CareerGoal[]
  missions       Mission[]
  missionCompetencies MissionCompetencyState[]
  weeklyPlans    WeeklyPlan[]
  planItems      PlanItem[]
  missionCheckIns MissionCheckIn[]
  jobApplications JobApplication[]
  jobEvents      JobEvent[]
  tasks          Task[]
  reminders      Reminder[]
  learningSources LearningSource[]
  learningHighlights LearningHighlight[]
  learningEvidence LearningEvidence[]
  readwiseConnection ReadwiseConnection?
  readwiseSyncRuns ReadwiseSyncRun[]

  @@map("users")
}

model Topic {
  id             String          @id @default(uuid()) @db.Uuid
  name           String
  parentTopicId  String?         @map("parent_topic_id") @db.Uuid
  description    String?
  createdAt      DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  parentTopic    Topic?          @relation("TopicHierarchy", fields: [parentTopicId], references: [id], onDelete: SetNull)
  childTopics    Topic[]         @relation("TopicHierarchy")
  questions      Question[]
  studyPlanItems StudyPlanItem[]
  tasks          Task[]
  learningHighlights LearningHighlight[]
  learningEvidence LearningEvidence[]

  @@index([parentTopicId])
  @@map("topics")
}

model Company {
  id        String            @id @default(uuid()) @db.Uuid
  name      String
  region    String?
  notes     String?
  createdAt DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  questions QuestionCompany[]

  @@map("companies")
}

model Question {
  id               String            @id @default(uuid()) @db.Uuid
  title            String
  prompt           String
  type             String
  difficulty       String
  topicId          String            @map("topic_id") @db.Uuid
  subtopic         String?
  referenceAnswer  String?           @map("reference_answer")
  notes            String?
  sourceUrl        String?           @map("source_url")
  roleTags         Json              @default("[]") @map("role_tags")
  areaTags         Json              @default("[]") @map("area_tags")
  patternTags      Json              @default("[]") @map("pattern_tags")
  estimatedMinutes Int?              @map("estimated_minutes")
  rubric           Json              @default("{}")
  importance       Int               @default(1)
  createdByUserId  String            @map("created_by_user_id") @db.Uuid
  createdAt        DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  topic            Topic             @relation(fields: [topicId], references: [id], onDelete: Restrict)
  createdBy        User              @relation(fields: [createdByUserId], references: [id], onDelete: Cascade)
  companies        QuestionCompany[]
  sessionQuestions SessionQuestion[]
  answerAttempts   AnswerAttempt[]
  learningEvidence LearningEvidence[]

  @@index([topicId])
  @@index([createdByUserId])
  @@index([type])
  @@index([difficulty])
  @@index([importance])
  @@map("questions")
}

model QuestionCompany {
  questionId String   @map("question_id") @db.Uuid
  companyId  String   @map("company_id") @db.Uuid
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@id([questionId, companyId])
  @@index([companyId])
  @@map("question_companies")
}

model InterviewSession {
  id               String            @id @default(uuid()) @db.Uuid
  userId           String            @map("user_id") @db.Uuid
  title            String?
  sessionType      String            @map("session_type")
  status           String            @default("active")
  roleTrackId      String?           @map("role_track_id")
  area             String?
  practiceMode     String?           @map("practice_mode")
  jobApplicationId String?           @map("job_application_id") @db.Uuid
  missionId        String?           @map("mission_id") @db.Uuid
  startedAt        DateTime          @default(now()) @map("started_at") @db.Timestamptz(6)
  endedAt          DateTime?         @map("ended_at") @db.Timestamptz(6)
  createdAt        DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobApplication   JobApplication?   @relation(fields: [jobApplicationId], references: [id], onDelete: SetNull)
  mission          Mission?          @relation(fields: [missionId], references: [id], onDelete: SetNull)
  sessionQuestions SessionQuestion[]
  answerAttempts   AnswerAttempt[]

  @@index([userId])
  @@index([status])
  @@index([roleTrackId])
  @@index([jobApplicationId])
  @@index([missionId])
  @@map("interview_sessions")
}

model SessionQuestion {
  id         String           @id @default(uuid()) @db.Uuid
  sessionId  String           @map("session_id") @db.Uuid
  questionId String           @map("question_id") @db.Uuid
  order      Int
  createdAt  DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  session    InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  question   Question         @relation(fields: [questionId], references: [id], onDelete: Restrict)

  @@unique([sessionId, order])
  @@index([questionId])
  @@map("session_questions")
}

model AnswerAttempt {
  id         String            @id @default(uuid()) @db.Uuid
  userId     String            @map("user_id") @db.Uuid
  sessionId  String?           @map("session_id") @db.Uuid
  questionId String            @map("question_id") @db.Uuid
  answerText String            @map("answer_text")
  selfRating Int?              @map("self_rating")
  aiScore    Float?            @map("ai_score")
  aiFeedback String?           @map("ai_feedback")
  correctness String?
  confidence Int?
  timeSpentSeconds Int?        @map("time_spent_seconds")
  hintUsed   Boolean           @default(false) @map("hint_used")
  rubricScore Float?           @map("rubric_score")
  needsReview Boolean          @default(false) @map("needs_review")
  createdAt  DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  session    InterviewSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  question   Question          @relation(fields: [questionId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([sessionId])
  @@index([questionId])
  @@index([needsReview])
  @@map("answer_attempts")
}

model StudyPlanItem {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  topicId    String?   @map("topic_id") @db.Uuid
  title      String
  notes      String?
  targetDate DateTime? @map("target_date") @db.Date
  status     String    @default("todo")
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic      Topic?    @relation(fields: [topicId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([topicId])
  @@index([status])
  @@map("study_plan_items")
}

model Profile {
  id          String         @id @default(uuid()) @db.Uuid
  userId      String         @unique @map("user_id") @db.Uuid
  name        String?
  email       String?
  githubUrl   String?        @map("github_url")
  linkedinUrl String?        @map("linkedin_url")
  skills      Json           @default("[]")
  experience  Json           @default("[]")
  education   Json           @default("[]")
  projects    Json           @default("[]")
  rawCvText   String?        @map("raw_cv_text")
  createdAt   DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  scores      ProfileScore[]

  @@index([userId])
  @@map("profiles")
}

model ProfileScore {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  profileId       String   @map("profile_id") @db.Uuid
  targetId        String   @map("target_id")
  targetLabel     String   @map("target_label")
  roleTemplate    String   @map("role_template")
  jdText          String?  @map("jd_text")
  skillsMatch     Float    @map("skills_match")
  projectQuality  Float    @map("project_quality")
  experienceDepth Float    @map("experience_depth")
  presentation    Float
  skillsGaps      Json     @default("[]") @map("skills_gaps")
  projectGaps     Json     @default("[]") @map("project_gaps")
  experienceGaps  Json     @default("[]") @map("experience_gaps")
  presentationGaps Json    @default("[]") @map("presentation_gaps")
  suggestions     Json     @default("[]")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile         Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([profileId])
  @@index([targetId])
  @@map("profile_scores")
}

model CareerGoal {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  roleTrackId String   @map("role_track_id")
  horizon     String   @default("6_months")
  status      String   @default("active")
  targetDate  DateTime? @map("target_date") @db.Date
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  missions    Mission[]

  @@unique([userId, roleTrackId])
  @@index([userId])
  @@index([status])
  @@map("career_goals")
}

model JobApplication {
  id                String             @id @default(uuid()) @db.Uuid
  userId            String             @map("user_id") @db.Uuid
  company           String
  roleTitle         String             @map("role_title")
  url               String?
  location          String?
  status            String             @default("saved")
  roleTrackId       String?            @map("role_track_id")
  jdText            String?            @map("jd_text")
  appliedDate       DateTime?          @map("applied_date") @db.Date
  deadline          DateTime?          @db.Date
  source            String?
  referralName      String?            @map("referral_name")
  visaTag           String?            @map("visa_tag")
  h1bCountLastYear  Int?               @map("h1b_count_last_year")
  compensationNotes String?            @map("compensation_notes")
  notes             String?
  createdAt         DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  missions          Mission[]
  events            JobEvent[]
  tasks             Task[]
  reminders         Reminder[]
  sessions          InterviewSession[]
  learningEvidence  LearningEvidence[]

  @@index([userId])
  @@index([status])
  @@index([roleTrackId])
  @@index([deadline])
  @@map("job_applications")
}

model JobEvent {
  id               String         @id @default(uuid()) @db.Uuid
  userId           String         @map("user_id") @db.Uuid
  jobApplicationId String         @map("job_application_id") @db.Uuid
  type             String
  title            String
  notes            String?
  eventAt          DateTime       @map("event_at") @db.Timestamptz(6)
  createdAt        DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobApplication   JobApplication @relation(fields: [jobApplicationId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([jobApplicationId])
  @@index([eventAt])
  @@map("job_events")
}

model Task {
  id                    String             @id @default(uuid()) @db.Uuid
  userId                String             @map("user_id") @db.Uuid
  title                 String
  notes                 String?
  type                  String             @default("study")
  status                String             @default("todo")
  priority              String             @default("medium")
  roleTrackId           String?            @map("role_track_id")
  area                  String?
  topicId               String?            @map("topic_id") @db.Uuid
  jobApplicationId      String?            @map("job_application_id") @db.Uuid
  missionId             String?            @map("mission_id") @db.Uuid
  plannedFor            DateTime?          @map("planned_for") @db.Timestamptz(6)
  dueDate               DateTime?          @map("due_date") @db.Timestamptz(6)
  recurrence            String?
  reminderOffsetMinutes Int?               @map("reminder_offset_minutes")
  completedAt           DateTime?          @map("completed_at") @db.Timestamptz(6)
  snoozedUntil          DateTime?          @map("snoozed_until") @db.Timestamptz(6)
  createdAt             DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  user                  User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic                 Topic?             @relation(fields: [topicId], references: [id], onDelete: SetNull)
  jobApplication        JobApplication?    @relation(fields: [jobApplicationId], references: [id], onDelete: Cascade)
  mission               Mission?           @relation(fields: [missionId], references: [id], onDelete: SetNull)
  reminders             Reminder[]
  learningEvidence      LearningEvidence[]
  planItems             PlanItem[]

  @@index([userId])
  @@index([status])
  @@index([type])
  @@index([roleTrackId])
  @@index([area])
  @@index([dueDate])
  @@index([plannedFor])
  @@index([missionId])
  @@map("tasks")
}

model Reminder {
  id               String          @id @default(uuid()) @db.Uuid
  userId           String          @map("user_id") @db.Uuid
  taskId           String?         @map("task_id") @db.Uuid
  jobApplicationId String?         @map("job_application_id") @db.Uuid
  type             String
  title            String
  dueAt            DateTime        @map("due_at") @db.Timestamptz(6)
  status           String          @default("pending")
  lastTriggeredAt  DateTime?       @map("last_triggered_at") @db.Timestamptz(6)
  dismissedAt      DateTime?       @map("dismissed_at") @db.Timestamptz(6)
  createdAt        DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  task             Task?           @relation(fields: [taskId], references: [id], onDelete: Cascade)
  jobApplication   JobApplication? @relation(fields: [jobApplicationId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([dueAt])
  @@index([taskId])
  @@index([jobApplicationId])
  @@map("reminders")
}

model LearningSource {
  id                 String              @id @default(uuid()) @db.Uuid
  userId             String              @map("user_id") @db.Uuid
  externalId         String?             @map("external_id")
  title              String
  author             String?
  url                String?
  sourceType         String              @map("source_type")
  category           String?
  summary            String?
  coverImageUrl      String?             @map("cover_image_url")
  readwiseUrl        String?             @map("readwise_url")
  isDeleted          Boolean             @default(false) @map("is_deleted")
  createdAt          DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  highlights         LearningHighlight[]
  learningEvidence   LearningEvidence[]

  @@unique([userId, externalId])
  @@index([userId])
  @@index([sourceType])
  @@map("learning_sources")
}

model LearningHighlight {
  id                 String             @id @default(uuid()) @db.Uuid
  userId             String             @map("user_id") @db.Uuid
  sourceId           String?            @map("source_id") @db.Uuid
  readwiseHighlightId Int?              @map("readwise_highlight_id")
  text               String
  note               String?
  color              String?
  location           String?
  locationType       String?            @map("location_type")
  highlightedAt      DateTime?          @map("highlighted_at") @db.Timestamptz(6)
  readwiseUpdatedAt  DateTime?          @map("readwise_updated_at") @db.Timestamptz(6)
  isDeleted          Boolean            @default(false) @map("is_deleted")
  reviewedAt         DateTime?          @map("reviewed_at") @db.Timestamptz(6)
  usefulness         String?
  roleTrackId        String?            @map("role_track_id")
  area               String?
  topicId            String?            @map("topic_id") @db.Uuid
  createdAt          DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  source             LearningSource?    @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  topic              Topic?             @relation(fields: [topicId], references: [id], onDelete: SetNull)
  evidence           LearningEvidence[]

  @@unique([userId, readwiseHighlightId])
  @@index([userId])
  @@index([sourceId])
  @@index([roleTrackId])
  @@index([area])
  @@index([topicId])
  @@index([reviewedAt])
  @@map("learning_highlights")
}

model LearningEvidence {
  id               String             @id @default(uuid()) @db.Uuid
  userId           String             @map("user_id") @db.Uuid
  type             String
  title            String
  body             String?
  roleTrackId      String?            @map("role_track_id")
  area             String?
  topicId          String?            @map("topic_id") @db.Uuid
  sourceId         String?            @map("source_id") @db.Uuid
  highlightId      String?            @map("highlight_id") @db.Uuid
  taskId           String?            @map("task_id") @db.Uuid
  questionId       String?            @map("question_id") @db.Uuid
  jobApplicationId String?            @map("job_application_id") @db.Uuid
  missionId        String?            @map("mission_id") @db.Uuid
  metadata         Json               @default("{}")
  occurredAt       DateTime           @default(now()) @map("occurred_at") @db.Timestamptz(6)
  createdAt        DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic            Topic?             @relation(fields: [topicId], references: [id], onDelete: SetNull)
  source           LearningSource?    @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  highlight        LearningHighlight? @relation(fields: [highlightId], references: [id], onDelete: SetNull)
  task             Task?              @relation(fields: [taskId], references: [id], onDelete: SetNull)
  question         Question?          @relation(fields: [questionId], references: [id], onDelete: SetNull)
  jobApplication   JobApplication?    @relation(fields: [jobApplicationId], references: [id], onDelete: SetNull)
  mission          Mission?           @relation(fields: [missionId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([roleTrackId])
  @@index([area])
  @@index([topicId])
  @@index([occurredAt])
  @@index([missionId])
  @@map("learning_evidence")
}

model Mission {
  id                String                 @id @default(uuid()) @db.Uuid
  userId            String                 @map("user_id") @db.Uuid
  name              String
  summary           String?
  sourceType        String                 @default("manual") @map("source_type")
  stage             String                 @default("diagnose")
  roleTrackId       String                 @map("role_track_id")
  careerGoalId      String?                @map("career_goal_id") @db.Uuid
  jobApplicationId  String?                @map("job_application_id") @db.Uuid
  targetDate        DateTime?              @map("target_date") @db.Date
  weeklyHours       Int                    @default(8) @map("weekly_hours")
  successDefinition String?                @map("success_definition")
  diagnosisSummary  String?                @map("diagnosis_summary")
  activePlanId      String?                @unique @map("active_plan_id") @db.Uuid
  createdAt         DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)
  user              User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  careerGoal        CareerGoal?            @relation(fields: [careerGoalId], references: [id], onDelete: SetNull)
  jobApplication    JobApplication?        @relation(fields: [jobApplicationId], references: [id], onDelete: SetNull)
  competencyStates  MissionCompetencyState[]
  sessions          InterviewSession[]
  tasks             Task[]
  learningEvidence  LearningEvidence[]
  plans             WeeklyPlan[]           @relation("MissionPlans")
  planItems         PlanItem[]
  activePlan        WeeklyPlan?            @relation("MissionActivePlan", fields: [activePlanId], references: [id], onDelete: SetNull)
  checkIns          MissionCheckIn[]

  @@index([userId])
  @@index([stage])
  @@index([roleTrackId])
  @@index([careerGoalId])
  @@index([jobApplicationId])
  @@map("missions")
}

model MissionCompetencyState {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  missionId      String   @map("mission_id") @db.Uuid
  checklistItemId String  @map("checklist_item_id")
  roleTrackId    String   @map("role_track_id")
  area           String
  title          String
  description    String
  evidenceType   String   @map("evidence_type")
  weight         Int
  targetLevel    Int      @default(3) @map("target_level")
  currentLevel   Int      @default(0) @map("current_level")
  confidence     Int      @default(0)
  status         String   @default("missing")
  rationale      String?
  evidenceCount  Int      @default(0) @map("evidence_count")
  lastEvidenceAt DateTime? @map("last_evidence_at") @db.Timestamptz(6)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mission        Mission  @relation(fields: [missionId], references: [id], onDelete: Cascade)

  @@unique([missionId, checklistItemId])
  @@index([userId])
  @@index([missionId])
  @@index([status])
  @@index([area])
  @@map("mission_competency_states")
}

model WeeklyPlan {
  id                    String           @id @default(uuid()) @db.Uuid
  userId                String           @map("user_id") @db.Uuid
  missionId             String           @map("mission_id") @db.Uuid
  weekStart             DateTime         @map("week_start") @db.Date
  weekEnd               DateTime         @map("week_end") @db.Date
  status                String           @default("active")
  focusSummary          String?          @map("focus_summary")
  generatedFromDiagnosis String?         @map("generated_from_diagnosis")
  totalPlannedHours     Int              @default(0) @map("total_planned_hours")
  createdAt             DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  user                  User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  mission               Mission          @relation("MissionPlans", fields: [missionId], references: [id], onDelete: Cascade)
  activeForMission      Mission?         @relation("MissionActivePlan")
  items                 PlanItem[]

  @@index([userId])
  @@index([missionId])
  @@index([status])
  @@index([weekStart])
  @@map("weekly_plans")
}

model PlanItem {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  planId           String    @map("plan_id") @db.Uuid
  missionId        String    @map("mission_id") @db.Uuid
  taskId           String?   @map("task_id") @db.Uuid
  title            String
  description      String?
  type             String
  status           String    @default("todo")
  roleTrackId      String?   @map("role_track_id")
  area             String?
  estimatedMinutes Int       @default(45) @map("estimated_minutes")
  expectedArtifact String?   @map("expected_artifact")
  scheduledFor     DateTime? @map("scheduled_for") @db.Timestamptz(6)
  completedAt      DateTime? @map("completed_at") @db.Timestamptz(6)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan             WeeklyPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  mission          Mission   @relation(fields: [missionId], references: [id], onDelete: Cascade)
  task             Task?     @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([planId])
  @@index([missionId])
  @@index([status])
  @@index([scheduledFor])
  @@map("plan_items")
}

model MissionCheckIn {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  missionId   String   @map("mission_id") @db.Uuid
  summary     String
  wins        String?
  blockers    String?
  adjustments String?
  checkInAt   DateTime @default(now()) @map("check_in_at") @db.Timestamptz(6)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mission     Mission  @relation(fields: [missionId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([missionId])
  @@index([checkInAt])
  @@map("mission_check_ins")
}

model ReadwiseConnection {
  id             String            @id @default(uuid()) @db.Uuid
  userId         String            @unique @map("user_id") @db.Uuid
  token          String?
  status         String            @default("disconnected")
  lastSyncedAt   DateTime?         @map("last_synced_at") @db.Timestamptz(6)
  nextPageCursor String?           @map("next_page_cursor")
  lastError      String?           @map("last_error")
  createdAt      DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("readwise_connections")
}

model ReadwiseSyncRun {
  id                  String   @id @default(uuid()) @db.Uuid
  userId              String   @map("user_id") @db.Uuid
  startedAt           DateTime @default(now()) @map("started_at") @db.Timestamptz(6)
  finishedAt          DateTime? @map("finished_at") @db.Timestamptz(6)
  status              String   @default("running")
  booksProcessed      Int      @default(0) @map("books_processed")
  highlightsProcessed Int      @default(0) @map("highlights_processed")
  deletedCount        Int      @default(0) @map("deleted_count")
  error               String?
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([startedAt])
  @@map("readwise_sync_runs")
}
