{
  "name": "@momito/api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "prebuild": "pnpm --filter @momito/shared build",
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "prisma:generate": "prisma generate",
    "seed": "prisma db seed",
    "test": "vitest run",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "content:validate": "tsx scripts/content-validate.ts",
    "content:stats": "tsx scripts/content-stats.ts",
    "content:sample": "tsx scripts/content-sample.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@momito/shared": "workspace:*",
    "@nestjs/common": "^11.1.3",
    "@nestjs/core": "^11.1.3",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/platform-express": "^11.1.27",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^6.19.0",
    "bcryptjs": "^3.0.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "helmet": "^8.2.0",
    "pdf-parse": "^2.4.5",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "ts-fsrs": "^5.4.1",
    "web-push": "^3.6.7",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.7",
    "@nestjs/testing": "^11.1.3",
    "@types/express": "^5.0.6",
    "@types/node": "^22.19.21",
    "@types/web-push": "^3.6.4",
    "eslint": "^9.39.4",
    "prisma": "^6.19.0",
    "tsx": "^4.20.6",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^3.2.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
