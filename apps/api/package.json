{
  "name": "@momito/api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "prebuild": "pnpm --filter @momito/shared build",
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "prisma:generate": "prisma generate",
    "seed": "prisma db seed",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@momito/shared": "workspace:*",
    "@nestjs/common": "^11.1.3",
    "@nestjs/core": "^11.1.3",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/platform-express": "^11.1.27",
    "@prisma/client": "^6.19.0",
    "bcryptjs": "^3.0.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "pdf-parse": "^2.4.5",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.7",
    "@nestjs/testing": "^11.1.3",
    "@types/node": "^22.15.30",
    "prisma": "^6.19.0",
    "tsx": "^4.20.6",
    "typescript": "^5.8.3",
    "vitest": "^3.2.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
